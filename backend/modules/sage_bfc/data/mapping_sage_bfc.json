  "regles_agregation": {
    "retrocessions": {
      "formule": "sum(mapping_retrocessions)",
      "calculee": true,
      "valeur_par_defaut": 0
    },
    "ca_net": {
      "formule": "CA Brut - Retrocessions",
      "dependances": ["CA Brut", "Retrocessions"]
    },
    "total_produits_exploitation": {
      "formule": "CA Net + Autres Produits d'Exploitation",
      "dependances": ["CA Net", "Autres Produits d'Exploitation"]
    },
    "total_charges_courantes": {
      "formule": "Frais de Personnel + Honoraires & Sous-traitance + Frais Commerciaux + Impôts et taxes + Fonctionnement Courant + Autres Charges",
      "dependances": ["Frais de Personnel", "Honoraires & Sous-traitance", "Frais Commerciaux", "Impôts et taxes", "Fonctionnement Courant", "Autres Charges"]
    },
    "ebitda": {
      "formule": "Total Produits d'Exploitation - Total Charges Courantes",
      "dependances": ["Total Produits d'Exploitation", "Total Charges Courantes"]
    },
    "ebitda_pct": {
      "formule": "EBITDA / CA Net * 100",
      "dependances": ["EBITDA", "CA Net"],
      "format": "pourcentage"
    },
    "resultat_financier": {
      "formule": "Produits Financiers - Charges Financières",
      "dependances": ["Produits Financiers", "Charges Financières"]
    },
    "resultat_exceptionnel": {
      "formule": "Produits Exceptionnels - Charges Exceptionnelles",
      "dependances": ["Produits Exceptionnels", "Charges Exceptionnelles"]
    },
    "resultat_avant_impot": {
      "formule": "EBITDA + Résultat Financier - Dotations Amortissements & Provisions + Résultat Exceptionnel",
      "dependances": ["EBITDA", "Résultat Financier", "Dotations Amortissements & Provisions", "Résultat Exceptionnel"]
    },
    "resultat_net": {
      "formule": "Résultat avant Impôt - Impôt sur les sociétés",
      "dependances": ["Résultat avant Impôt", "Impôt sur les sociétés"]
    },
    "resultat_net_pct": {
      "formule": "Résultat Net / CA Net * 100",
      "dependances": ["Résultat Net", "CA Net"],
      "format": "pourcentage"
    }
  },

